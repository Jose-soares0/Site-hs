---
const steps = [
  {
    title: "Avaliação da necessidade",
    description: "Entendimento do imóvel, veículo, rotina e pontos mais sensíveis antes de indicar equipamentos.",
  },
  {
    title: "Projeto da solução",
    description: "Definição de câmeras, alarmes, sensores, rastreamento e acompanhamento conforme o risco real.",
  },
  {
    title: "Instalação dos equipamentos",
    description: "Equipe técnica executa a instalação com foco em funcionamento, visibilidade e uso no dia a dia.",
  },
  {
    title: "Monitoramento e acompanhamento",
    description: "Alertas e sinais são acompanhados conforme o serviço contratado e os procedimentos definidos.",
  },
  {
    title: "Suporte quando precisar",
    description: "Atendimento local para orientar ajustes, dúvidas e evolução da proteção ao longo do tempo.",
  },
];
---

<section id="como-funciona" class="dark-surface section-space">
  <div class="section-shell relative z-10">
    <div class="max-w-3xl">
      <p class="eyebrow">Como funciona</p>
      <h2 class="section-title mt-4 text-white">Do primeiro contato ao monitoramento ativo.</h2>
      <p class="mt-5 text-lg leading-8 text-white/70">
        O processo precisa mostrar método: detectar, verificar, acionar e proteger. Segurança forte não nasce de improviso.
      </p>
    </div>

    <div class="timeline-track relative mt-14 grid gap-5">
      {steps.map((step, index) => (
        <article class="timeline-step grid gap-4 rounded-3xl border border-white/12 bg-white/6 p-5 backdrop-blur md:grid-cols-[96px_1fr] md:p-6">
          <div class="flex items-center gap-4 md:block">
            <span class="grid size-14 place-items-center rounded-2xl bg-gray-line font-display text-lg font-black text-black-hs">
              {String(index + 1).padStart(2, "0")}
            </span>
          </div>
          <div>
            <h3 class="font-display text-2xl font-black text-white">{step.title}</h3>
            <p class="mt-2 max-w-3xl leading-7 text-white/68">{step.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!reduceMotion) {
    gsap.from(".timeline-step", {
      scrollTrigger: {
        trigger: ".timeline-track",
        start: "top 78%",
      },
      autoAlpha: 0,
      y: 24,
      duration: 0.65,
      stagger: 0.12,
      ease: "power3.out",
    });
  }
</script>
