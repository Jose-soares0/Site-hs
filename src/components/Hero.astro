---
import WhatsAppButton from "./WhatsAppButton.astro";
import { site } from "@data/site";
---

<section id="topo" class="dark-surface min-h-screen pt-24">
  <div class="section-shell relative z-10 flex min-h-[calc(100vh-6rem)] items-center pb-14">
    <div class="max-w-5xl">
      <img
        class="mb-6 h-20 w-20 rounded-2xl border border-white/14 bg-black-hs object-contain p-2 shadow-2xl shadow-black/30 sm:h-24 sm:w-24"
        src={site.logo}
        alt="Logo HS Seg"
        width="96"
        height="96"
      />
      <h1 class="display-title max-w-4xl text-[clamp(2.25rem,5vw,4.6rem)] leading-[1.06] text-white">
        Somos a sua segurança 24hrs
      </h1>
      <p class="mt-7 max-w-3xl text-base leading-8 text-white/74 sm:text-lg">
        Segurança de verdade é ter quem monitora, acompanha e age. Seu patrimônio com tecnologia avançada, monitoramento constante e suporte local especializado.
      </p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <WhatsAppButton />
        <a class="secondary-button" href="#solucoes">Ver soluções</a>
      </div>

      <div class="mt-10 grid max-w-3xl gap-3 sm:grid-cols-3">
        {["8 anos de experiência", "Monitoramento 24h", "Atendimento no Piauí"].map((item) => (
          <div class="rounded-2xl border border-white/12 bg-white/6 px-4 py-3">
            <span class="mb-2 block h-1 w-8 rounded-full bg-gray-line"></span>
            <span class="text-sm font-bold text-white/84">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
