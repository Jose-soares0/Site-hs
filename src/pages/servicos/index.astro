---
import BaseLayout from "@layouts/BaseLayout.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import WhatsAppButton from "@components/WhatsAppButton.astro";
import { services } from "@data/services";
---

<BaseLayout
  title="Serviços da HS Seg | Segurança Eletrônica no Piauí"
  description="Conheça os serviços da HS Seg: monitoramento 24h, câmeras, alarmes, rastreamento veicular e segurança para empresas e condomínios."
>
  <Header />
  <main id="conteudo" class="bg-white pt-28">
    <section class="section-space">
      <div class="section-shell">
        <p class="eyebrow">Serviços</p>
        <h1 class="display-title mt-4 max-w-4xl text-[clamp(2rem,4.6vw,4.2rem)] leading-[1.04] text-black-hs">
          Soluções de segurança eletrônica para cada tipo de risco.
        </h1>
        <p class="lead-text mt-6 max-w-2xl">
          Esta página está preparada para crescer com páginas individuais de serviço, cases reais e conteúdo de SEO local.
        </p>
        <WhatsAppButton class="mt-8" />
      </div>
    </section>

    <section class="pb-20">
      <div class="section-shell grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((service) => (
          <article class="technical-card p-5">
            <span class="grid size-14 place-items-center rounded-2xl bg-black-hs font-display text-sm font-black text-white">
              {service.label}
            </span>
            <h2 class="mt-6 font-display text-lg font-black text-black-hs">{service.title}</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">{service.description}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
